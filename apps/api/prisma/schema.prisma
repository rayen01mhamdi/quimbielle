generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum FormStatus {
  DRAFT
  FINALIZED
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  name         String
  passwordHash String
  isAdmin      Boolean       @default(false)
  createdAt    DateTime      @default(now())
  forms        Form[]
  fieldPositions FieldPosition[]
  settings     UserSettings?
}

model FormTemplate {
  id            String   @id @default(uuid())
  name          String
  imageUrl      String
  paperWidthCm  Float    @default(17.5)
  paperHeightCm Float    @default(11.5)
  fieldDefinitions Json
  createdAt     DateTime @default(now())
  forms         Form[]
}

model Form {
  id           String      @id @default(uuid())
  userId       String
  templateId   String
  beneficiary  String
  amount       Float
  dueDate      String
  ribTireur    String      @default("")
  ribTire      String      @default("")
  lieuCreation String      @default("")
  dateCreation String      @default("")
  status       FormStatus  @default(DRAFT)
  fieldValues  Json
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  user         User         @relation(fields: [userId], references: [id])
  template     FormTemplate @relation(fields: [templateId], references: [id])

  @@index([userId])
  @@index([beneficiary])
  @@index([dueDate])
}

model FieldPosition {
  id         String @id @default(uuid())
  userId     String
  templateId String
  fieldKey   String
  left       Float
  top        Float
  width      Float
  height     Float

  user       User   @relation(fields: [userId], references: [id])

  @@unique([userId, templateId, fieldKey])
  @@index([userId, templateId])
}

model UserSettings {
  id       String  @id @default(uuid())
  userId   String  @unique
  inkColor String  @default("#000000")
  fontSize Int     @default(8)
  pdfMode  String  @default("overlay")
  xOffset  Float   @default(0)
  yOffset  Float   @default(0)

  user     User    @relation(fields: [userId], references: [id])
}