generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String
  passwordHash String
  isAdmin      Boolean  @default(false)
  createdAt    DateTime @default(now())
  forms        FormRecord[]
}

model FormRecord {
  id        String   @id @default(uuid())
  userId    String
  values    Json
  positions Json
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}
